# ===== 服务器 =====
PORT=8080
ENV=development
READ_TIMEOUT=15s
WRITE_TIMEOUT=30s
SHUTDOWN_TIMEOUT=10s
# CORS 允许的源，逗号分隔；开发用 *，生产填实际域名
# 例如：https://clip.example.com,http://localhost:3000
ALLOWED_ORIGINS=*

# ===== 数据库 =====
# 留空则使用 SQLite；填 postgres://user:pass@host:5432/dbname?sslmode=disable 切换为 PostgreSQL
DATABASE_URL=
SQLITE_PATH=./data/clipboard.db

# ===== 对象存储 =====
# local: 本地文件系统（默认）| s3: S3 兼容存储（阶段 5 实现占位，暂未启用）
BLOB_STORE=local
BLOB_LOCAL_DIR=./data/blobs
# 以下仅 BLOB_STORE=s3 时使用
S3_ENDPOINT=
S3_BUCKET=
S3_KEY=
S3_SECRET=
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true

# ===== 鉴权 =====
# 必填：随机字符串 ≥32 字节
# 生成方式：openssl rand -base64 64
JWT_SECRET=change-me-to-a-random-secret-at-least-32-bytes-long
ACCESS_TTL=15m
REFRESH_TTL=720h
# Argon2id 参数（默认值适用于大多数场景，调高增加安全性但降低性能）
ARGON2_MEMORY=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=2

# ===== 注册策略 =====
# closed: 仅管理员创建（默认）| invite: 邀请码注册 | open: 开放注册
ALLOW_REGISTER=closed

# ===== 默认用户配额 =====
# 单条上限（字节），默认 10MB
DEFAULT_MAX_ITEM_SIZE=10485760
# 总配额（字节），默认 1GB
DEFAULT_QUOTA_BYTES=1073741824
# 保留天数
DEFAULT_RETENTION_DAYS=30

# ===== 限流 =====
# 每用户每分钟最大请求数
RATE_LIMIT_PER_MINUTE=60

# ===== 日志 =====
# json | text
LOG_FORMAT=json
# debug | info | warn | error
LOG_LEVEL=info

# ===== 管理员引导（首次启动自动创建）=====
# 仅当数据库中无任何用户时生效
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# 生产环境请设置强密码（≥12 字符）
